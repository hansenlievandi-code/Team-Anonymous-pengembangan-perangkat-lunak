// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js" // Pastikan menggunakan prisma-client-js
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Specialization {
  KARDIOLOGI_UMUM         @map("Kardiologi Umum")
  KARDIOLOGI_INTERVENSI   @map("Kardiologi Intervensi")
  ELEKTROFISIOLOGI        @map("Elektrofisiologi")
  EKOKARDIOGRAFI          @map("Ekokardiografi")
  KARDIOLOGI_ANAK         @map("Kardiologi Anak")
  BEDAH_KARDIOTORAKS      @map("Bedah Kardiotoraks")
  SPESIALIS_GAGAL_JANTUNG @map("Spesialis Gagal Jantung")
}

enum Hari {
  Senin  @map("Senin")
  Selasa @map("Selasa")
  Rabu   @map("Rabu")
  Kamis  @map("Kamis")
  Jumat  @map("Jumat")
  Sabtu  @map("Sabtu")
  Minggu @map("Minggu")
}

enum JenisKelamin {
  Laki_laki @map("Laki-laki")
  Perempuan @map("Perempuan")
}

enum Status {
  Terjadwal  @map("Terjadwal")
  Selesai    @map("Selesai")
  Dibatalkan @map("Dibatalkan")
}

model InfDokter {
  id              Int               @id @default(autoincrement())
  namaLengkap     String            @map("nama_lengkap") @db.VarChar(255)
  subSpesialisasi Specialization    @map("sub_spesialisasi")
  email           String            @unique @db.VarChar(150)
  nomorTelepon    String            @map("nomor_telepon") @db.VarChar(50)
  mulaiPraktik    DateTime          @map("mulai_praktik") @db.Date

  jadwal          InfJadwalDokter[]
  janjiTemu       InfJanjiTemu[]

  @@map("inf_dokter")
}

model InfJadwalDokter {
  id                Int            @id @default(autoincrement())
  id_dokter         Int
  hari              Hari           @map("hari")
  jam_buka          DateTime       @map("jam_buka") @db.Time
  jam_tutup         DateTime       @map("jam_tutup") @db.Time
  durasi_slot_menit Int            @map("durasi_slot_menit")

  dokter            InfDokter      @relation(fields: [id_dokter], references: [id], onDelete: Cascade)
  janjiTemu         InfJanjiTemu[]

  @@map("inf_jadwal_dokter")
}

model InfPasien {
  id            Int            @id @default(autoincrement())
  nama_lengkap  String         @map("nama_lengkap") @db.VarChar(255)
  nik           String         @unique @map("nik") @db.Char(16)
  jenis_kelamin JenisKelamin   @map("jenis_kelamin")
  tanggal_lahir DateTime       @map("tanggal_lahir") @db.Date
  alamat        String?        @map("alamat") @db.Text
  nomor_telepon String?        @map("nomor_telepon") @db.VarChar(20)

  janjiTemu     InfJanjiTemu[]

  @@map("inf_pasien")
}

model InfJanjiTemu {
  id          Int       @id @default(autoincrement())
  id_dokter   Int       @map("id_dokter")
  id_pasien   Int       @map("id_pasien")
  id_jadwal   Int       @map("id_jadwal")
  waktu_janji DateTime  @map("waktu_janji") @db.DateTime
  status      Status    @map("status") @default(Terjadwal)
  catatan     String?   @map("catatan") @db.Text

  dokter      InfDokter       @relation(fields: [id_dokter], references: [id])
  pasien      InfPasien       @relation(fields: [id_pasien], references: [id])
  jadwal      InfJadwalDokter @relation(fields: [id_jadwal], references: [id])

  @@map("inf_janji_temu")
}